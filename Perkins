<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SoonTM RP | FiveM Server</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#0d0d0d;
    color:white;
}

nav{
    position:fixed;
    width:100%;
    top:0;
    left:0;
    z-index:1000;
    background:rgba(0,0,0,0.9);
    backdrop-filter:blur(10px);
}

.nav-container{
    max-width:1200px;
    margin:auto;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px;
}

.logo{
    font-size:1.8rem;
    font-weight:800;
    color:#ff1a1a;
}

.nav-links{
    display:flex;
    gap:30px;
}

.nav-links a{
    color:white;
    text-decoration:none;
    transition:0.3s;
}

.nav-links a:hover{
    color:#ff1a1a;
}

.hero{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    background:
    linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.8)),
    url('https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=2000&auto=format&fit=crop');
    background-size:cover;
    background-position:center;
}

.hero-content h1{
    font-size:5rem;
    font-weight:800;
}

.hero-content span{
    color:#ff1a1a;
}

.hero-content p{
    margin-top:15px;
    font-size:1.2rem;
    color:#cfcfcf;
}

.buttons{
    margin-top:30px;
}

.btn{
    display:inline-block;
    padding:14px 30px;
    margin:10px;
    text-decoration:none;
    border-radius:8px;
    transition:0.3s;
    font-weight:600;
}

.btn-primary{
    background:#ff1a1a;
    color:white;
}

.btn-primary:hover{
    background:#cc0000;
}

.btn-secondary{
    border:2px solid #ff1a1a;
    color:white;
}

.btn-secondary:hover{
    background:#ff1a1a;
}

section{
    padding:100px 20px;
}

.container{
    max-width:1200px;
    margin:auto;
}

.section-title{
    text-align:center;
    font-size:3rem;
    margin-bottom:50px;
    color:#ff1a1a;
}

.features{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:#151515;
    padding:30px;
    border-radius:15px;
    border:1px solid #222;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-8px);
    border-color:#ff1a1a;
}

.card h3{
    margin-bottom:10px;
}

.rules{
    display:grid;
    gap:20px;
}

.rule{
    background:#151515;
    padding:20px;
    border-left:4px solid #ff1a1a;
    border-radius:8px;
}

.discord{
    text-align:center;
}

.discord-box{
    background:#151515;
    max-width:700px;
    margin:auto;
    padding:40px;
    border-radius:20px;
}

.discord-box h3{
    font-size:2rem;
    margin-bottom:20px;
}

footer{
    text-align:center;
    padding:30px;
    background:black;
    color:#888;
}

.online-status{
    color:#4dff4d;
    font-weight:bold;
}
</style>
</head>
<body>

<nav>
    <div class="nav-container">
        <div class="logo">SoonTM RP</div>

        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#rules">Rules</a>
            <a href="#discord">Discord</a>
        </div>
    </div>
</nav>

<section class="hero" id="home">
    <div class="hero-content">
        <h1>WELCOME TO <span>SoonTM RP</span></h1>
        <p>Premium FiveM Roleplay Experience</p>

        <p class="online-status">
            ● Server Online
        </p>

        <div class="buttons">
            <a href="#" class="btn btn-primary">Connect Now</a>
            <a href="#discord" class="btn btn-secondary">Join Discord</a>
        </div>
    </div>
</section>

<section>
    <div class="container">
        <h2 class="section-title">Why Choose Us?</h2>

        <div class="features">
            <div class="card">
                <h3>Custom Scripts</h3>
                <p>Unique gameplay systems built specifically for our community.</p>
            </div>

            <div class="card">
                <h3>Active Staff</h3>
                <p>Friendly and professional moderation team available daily.</p>
            </div>

            <div class="card">
                <h3>Serious RP</h3>
                <p>High-quality roleplay environment for all players.</p>
            </div>

            <div class="card">
                <h3>Economy System</h3>
                <p>Balanced jobs, businesses and progression systems.</p>
            </div>
        </div>
    </div>
</section>

<section id="rules">
    <div class="container">
        <h2 class="section-title">Server Rules</h2>

        <div class="rules">
            <div class="rule">
                Respect all players and staff members.
            </div>

            <div class="rule">
                No cheating, exploiting, or use of third-party modifications.
            </div>

            <div class="rule">
                No Random Death Match (RDM) or Vehicle Death Match (VDM).
            </div>

            <div class="rule">
                Remain in character during roleplay situations.
            </div>

            <div class="rule">
                Use common sense and create realistic roleplay.
            </div>
        </div>
    </div>
</section>

<section id="discord">
    <div class="container discord">
        <h2 class="section-title">Join Our Discord</h2>

        <div class="discord-box">
            <h3>Become Part of the Community</h3>

            <p>
                Stay updated with announcements, applications,
                giveaways, and server events.
            </p>

            <br>

            <a href="https://discord.gg/YOURINVITE"
               class="btn btn-primary">
                Join Discord
            </a>
        </div>
    </div>
</section>

<footer>
    © 2026 SoonTM| FiveM Community
</footer>

</body>
</html>